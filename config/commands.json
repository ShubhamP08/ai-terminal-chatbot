{\n  "commands": {\n    "install_python": {\n      "description": "Installs Python on the system.",\n      "command": "sudo apt-get install python3"\n    },\n    "install_pandas": {\n      "description": "Installs Pandas for Python.",\n      "command": "pip install pandas"\n    },\n    "install_nodejs": {\n      "description": "Installs Node.js on the system.",\n      "command": "curl -sL https://deb.nodesource.com/setup_14.x | sudo -E bash - && sudo apt-get install -y nodejs"\n    },\n    "install_npm_package": {\n      "description": "Installs a specified npm package.",\n      "command": "npm install <package_name>"\n    },\n    "create_file": {\n      "description": "Creates a new file in the specified path.",\n      "command": "touch <file_name>"\n    },\n    "create_directory": {\n      "description": "Creates a new directory.",\n      "command": "mkdir <directory_name>"\n    },\n    "delete_file": {\n      "description": "Deletes a specified file.",\n      "command": "rm <file_name>"\n    },\n    "delete_directory": {\n      "description": "Deletes a specified directory.",\n      "command": "rm -r <directory_name>"\n    },\n    "list_files": {\n      "description": "Lists all files in the specified directory.",\n      "command": "ls <directory_name>"\n    },\n    "run_python_script": {\n      "description": "Runs a specified Python script.",\n      "command": "python <script_name.py>"\n    },\n    "create_virtual_env": {\n      "description": "Creates a virtual environment for Python projects.",\n      "command": "python -m venv <env_name>"\n    },\n    "install_git": {\n      "description": "Installs Git on the system.",\n      "command": "sudo apt-get install git"\n    }\n  }\n}